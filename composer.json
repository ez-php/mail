{
  "name": "ez-php/mail",
  "version": "0.8.0",
  "description": "Transactional mail module for the ez-php framework — SMTP, log, and null drivers",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Andreas Uretschnig",
      "email": "andreas.uretschnig@gmail.com"
    }
  ],
  "keywords": ["mail", "smtp", "email", "php", "framework", "ez-php"],
  "homepage": "https://github.com/ez-php/mail",
  "support": {
    "issues": "https://github.com/ez-php/mail/issues",
    "source": "https://github.com/ez-php/mail"
  },
  "require": {
    "php": "^8.5",
    "ez-php/contracts": "0.*"
  },
  "require-dev": {
    "ez-php/docker": "0.*",
    "phpunit/phpunit": "^13.0",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpstan/phpstan-deprecation-rules": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "EzPhp\\Mail\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "cs": "php-cs-fixer fix",
    "analyse": "phpstan analyse",
    "test": "phpunit",
    "full": "composer analyse && composer cs && composer test"
  }
}
